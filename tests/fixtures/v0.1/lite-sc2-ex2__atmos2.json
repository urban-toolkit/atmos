{
  "data": [
    {
      "id": "wrf",
      "source": {
        "type": "netcdf",
        "path": "wrfout.nc"
      },
      "dims": {
        "lat": {
          "key": "lat"
        },
        "lon": {
          "key": "lng"
        },
        "time": {
          "key": "time"
        }
      },
      "grid": {
        "type": "curvilinear"
      },
      "vars": [
        {
          "id": "RAINC",
          "key": "RAINC"
        },
        {
          "id": "RAINNC",
          "key": "RAINNC"
        }
      ]
    }
  ],
  "transform": [
    {
      "type": "derive",
      "expr": {
        "op": "add",
        "args": [
          {
            "data": "wrf",
            "var": "RAINC"
          },
          {
            "data": "wrf",
            "var": "RAINNC"
          }
        ]
      },
      "out": {
        "data": "rain",
        "var": "rain"
      }
    }
  ],
  "composition": {
    "views": [
      {
        "id": "v1",
        "frame": {
          "type": "map"
        },
        "layers": [
          {
            "id": "l1",
            "geometry": {
              "type": "isoband",
              "input": {
                "data": "rain",
                "var": "rain"
              },
              "build": [
                {
                  "levels": {
                    "type": "step",
                    "start": 0,
                    "stop": 160,
                    "step": 2
                  }
                }
              ],
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "rain",
                    "scale": {
                      "scheme": "Viridis",
                      "domain": [
                        0,
                        160
                      ]
                    }
                  }
                }
              }
            }
          }
        ]
      }
    ],
    "interactions": [
      {
        "type": "slider",
        "action": {
          "select": {
            "dim": "time",
            "target": [
              {
                "view": "v1",
                "layers": [
                  "l1"
                ]
              }
            ]
          }
        }
      }
    ]
  }
}
