{
  "data": [
    {
      "id": "wrf_ens",
      "kind": "collection",

      "members": {
        "count": 3,
        "indexStart": 0,
        "idPattern": "m{index}"
      },

      "sourceTemplate": {
        "type": "netcdf",
        "pathTemplate": "tests/data/ens/{id}/wrfout_d03_2011-01-10_00_00_00"
      },

      "memberDimension": "member",

      "dimensions": {
        "latitude": { "key": "XLAT" },
        "longitude": { "key": "XLONG" },
        "time": {
          "dim": "Time",
          "key": "Times",
          "type": "datetime",
          "timezone": "UTC",
          "format": "WRF_Times"
        }
      },

      "variables": [
        { "id": "rainnc", "key": "RAINNC", "kind": "grid" },
        { "id": "rainc", "key": "RAINC", "kind": "grid" }
      ],

      "description": "WRF ensemble"
    }
  ],

  "transform": [
    {
      "type": "derive",
      "across": "space",
      "input": {
        "data": "wrf_ens"
      },
      "expression": {
        "op": "add",
        "args": [
          { "variable": "rainnc" },
          { "variable": "rainc" }
        ]
      },
      "output": {
        "data": "membersAccRain",
        "variables": [
          { "id": "accRain", "kind": "grid" }
        ]
      }
    },
    {
      "type": "reduce",
      "input": "accRain",
      "across": "member",
      "op": "mean",
      "output": {
        "data": "ensAccRainMean",
        "variables": [{ "id": "accRainMean", "kind": "grid" }]
      }
    }
  ],

  "composition": {
    "views": [
      {
        "id": "view1",
        "frame": { "type": "map" },
        "layers": [
          {
            "id": "rain",
            "geometry": {
              "type": "mesh",
              "input": { "data": "ensAccRainMean", "variable": "accRainMean" },
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "accRainMean",
                    "scale": {
                      "type": "linear",
                      "range": {
                        "stops": [
                          { "value": 0, "color": "#a50026" },
                          { "value": 10, "color": "#d73027" },
                          { "value": 20, "color": "#f46d43" },
                          { "value": 30, "color": "#fdae61" },
                          { "value": 40, "color": "#fee090" },
                          { "value": 50, "color": "#ffffbf" },
                          { "value": 60, "color": "#e3f4f8" },
                          { "value": 70, "color": "#c6e6f1" },
                          { "value": 80, "color": "#abd9e9" },
                          { "value": 90, "color": "#74add1" },
                          { "value": 100, "color": "#4575b4" },
                          { "value": 110, "color": "#3b5ba9" },
                          { "value": 120, "color": "#313695" },
                          { "value": 130, "color": "#3f2f8a" },
                          { "value": 140, "color": "#54278f" },
                          { "value": 150, "color": "#6a1b9a" },
                          { "value": 160, "color": "#7b1fa2" }
                        ]
                      },
                      "clamp": false
                    }
                  },
                  "opacity": { "value": 0.9 }
                },
                "style": {
                  "nodataColor": "rgba(0,0,0,0)"
                }
              }
            }
          },
          {
            "id": "bound",
            "geometry": {
              "type": "polygon",
              "input": { "data": "boundaries" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                }
              }
            }
          }
        ]
      }
    ]
  }
}