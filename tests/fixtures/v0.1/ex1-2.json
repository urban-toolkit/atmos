{
  "data": [
    {
      "id": "boundaries",
      "source": { "type": "geojson", "path": "../../data/boundaries.geojson" },
      "properties": {
        "geoid": { "key": "GEOID" }
      }
    }
  ],

  "transform": [
    {
      "type": "derive_wind_speed",
      "as": { "id": "wind_speed" },
      "u": "u10",
      "v": "v10"
    },
    {
      "type": "derive_wind_direction",
      "as": { "id": "wind_dir" },
      "u": "u10",
      "v": "v10"
    }
  ],
  
  "composition": {
    "views": [
      {
        "id": "view1",
        "frame": { "type": "map" },
        "layers": [
          {
            "id": "bound",
            "geometry": {
              "type": "polygon",
              "input": { "data": "boundaries" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                },
                "style": {
                  "polygon": {
                    "strokeWidth": 1
                  }
                }
              }
            }
          }
        ]
      }
    ]
  }
}
