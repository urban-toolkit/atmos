{
  "data": [
    {
      "id": "stations_obs",
      "kind": "dataset",
      "source": {
        "type": "csv",
        "path": "tests/data/stations.csv"
      },

      "dimensions": {
        "site": { "key": "name" },
        "latitude": { "key": "lat" },
        "longitude": { "key": "lon" },
        "time": {
          "key": "zulu",
          "type": "datetime",
          "timezone": "UTC"
        }
      },
      
      "variables": [
        { "id": "accRain", "key": "obs", "kind": "point" }
      ],

      "description": "Station observations stored as rows."
    },
    {
      "id": "boundaries",
      "source": { "type": "geojson", "path": "tests/data/grid3P.geojson" },
      "properties": {
        "geoid": { "key": "GEOID" }
      }
    }
  ],
  
  "composition": {
    "layout": {
      "columns": 2,
      "repeatView": [
        {
          "type": "timestep",
          "indices": [0, 1],
          "targetView": "view1",
          "targetLayer": "stations"
        }
      ]
    },

    "views": [
      {
        "id": "view1",
        "frame": { "type": "map" },
        "layers": [
          {
            "id": "stations",
            "geometry": {
              "type": "point",
              "input": { "data": "stations_obs", "variable": "accRain" },
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "accRain",
                    "scale": {
                      "type": "linear",
                      "range": {
                        "stops": [
                          { "value": 0, "color": "#a50026" },
                          { "value": 10, "color": "#d73027" },
                          { "value": 20, "color": "#f46d43" },
                          { "value": 30, "color": "#fdae61" },
                          { "value": 40, "color": "#fee090" },
                          { "value": 50, "color": "#ffffbf" },
                          { "value": 60, "color": "#e3f4f8" },
                          { "value": 70, "color": "#c6e6f1" },
                          { "value": 80, "color": "#abd9e9" },
                          { "value": 90, "color": "#74add1" },
                          { "value": 100, "color": "#4575b4" },
                          { "value": 110, "color": "#3b5ba9" },
                          { "value": 120, "color": "#313695" },
                          { "value": 130, "color": "#3f2f8a" },
                          { "value": 140, "color": "#54278f" },
                          { "value": 150, "color": "#6a1b9a" },
                          { "value": 160, "color": "#7b1fa2" }
                        ]
                      },
                      "clamp": false
                    }
                  },
                  "opacity": { "value": 0.9 }
                },
                "style": {
                  "nodataColor": "rgba(0,0,0,0)"
                }
              }
            }
          },
          {
            "id": "bound",
            "geometry": {
              "type": "polygon",
              "input": { "data": "boundaries" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                },
                "style": {
                  "strokeWidth": 1
                }
              }
            }
          }
        ]
      }
    ]
  }
}
