{
  "format": "atmos",
  "data": [
    {
      "id": "wrfEns",
      "type": "collection",

      "members": {
        "count": 5,
        "indexStart": 0,
        "idPattern": "m{index}"
      },

      "sourceTemplate": {
        "type": "netcdf",
        "pathTemplate": "tests/data/ens/{id}/wrfout_d03_2011-01-10_00_00_00"
      },

      "grid": {
        "type": "curvilinear"
      },

      "dims": {
        "lat": { "key": "XLAT" },
        "lon": { "key": "XLONG" },
        "time": {
          "dim": "Time",
          "key": "Times",
          "type": "datetime",
          "timezone": "UTC",
          "format": "WRF_Times"
        }
      },

      "vars": [
        { "id": "rainnc", "key": "RAINNC" },
        { "id": "rainc", "key": "RAINC" },
        { "id": "t2", "key": "T2" }
      ]
    },
    {
      "id": "boundaries",
      "source": { "type": "geojson", "path": "tests/data/grid3P.geojson" },
      "dims": {
        "id": { "key": "GEOID" }
      }
    }
  ],

  "transform": [
    {
      "type": "derive",
      "expr": {
        "op": "add",
        "args": [
          { "data": "wrfEns", "var": "rainnc" },
          { "data": "wrfEns", "var": "rainc" }
        ]
      },
      "out": { "data": "wrfEnsRain", "var": "accRain" }
    },
    {
      "type": "reduce",
      "across": "member",
      "expr": {
        "op": "prob",
          "args": [
            {
              "op": "gt",
              "args": [
                { "data": "wrfEnsRain", "var": "accRain" },
                { "const": 50 }
              ]
            }
          ]
      },
      "out": {
        "data": "wrfEnsRainProb",
        "var": "probRain50"
      }
    },
    {
      "type": "reduce",
      "across": "member",
      "expr": {
        "op": "prob",
        "args": [
          {
            "op": "gt",
            "args": [
              { "data": "wrfEns", "var": "t2" },
              { "const": 14 }
            ]
          }
        ]
      },
      "out": {
        "data": "wrfEnsT2Prob",
        "var": "probT214"
      }
    }
  ],

  "composition": {
    "layout": {
      "columns": 1
    },
    "context": {
      "title": {
        "text": "Probability Accumulated Rain > 50mm at Time Step 72"
      },
      "legends": [
        {
          "title": "Probability",
          "type": "color",
          "source": [
            {
              "view": "v1",
              "layers": ["l1"],
              "channel": "fill"
            }
          ]
        }
      ]
    },
    
    "views": [
      {
        "id": "v1",
        "frame": { "type": "map" },
        "context": {
          "title": {
            "template": "Probability Acc Rain > 50 mm at Time Step 72"
          }
        },
        "layers": [
          {
            "id": "l1",
            "geometry": {
              "type": "mesh",
              "input": { "data": "wrfEnsRainProb", "var": "probRain50", "dims": { "time": 72 } },
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "probRain50",
                    "scale": {
                      "type": "sequential",
                      "scheme": "Greens",
                      "domain": [0, 1],
                      "clamp": false
                    }
                  },
                  "opacity": { "value": 1.0 }
                }
              }
            }
          },
          {
            "id": "bound",
            "geometry": {
              "type": "polygon",
              "input": { "data": "boundaries" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                }
              }
            }
          }
        ]
      }
    ]
  }
}