{
  "data": [
    {
      "id": "t2WRFUS",
      "source": { "type": "netcdf", "path": "tests/data/chicago/t2_reconstructed.nc" },
      "dims": {
        "lat": { "key": "XLAT" },
        "lon": { "key": "XLONG" },
        "time": { "dim": "Time", "key": "Times", "type": "datetime", "timezone": "UTC", "format": "" }
      },

      "grid": {
        "type": "curvilinear"
      },
      
      "vars": [
        { "id": "t2m", "key": "T2" }
      ]
    },
    {
      "id": "stationsMatch",
      "type": "dataset",
      "source": {
        "type": "csv",
        "path": "tests/data/chicago/matched_station_wrf.csv"
      },

      "grid": {
        "type": "scattered"
      },

      "dims": {
        "id": { "key": "id" },
        "lat": { "key": "latitude" },
        "lon": { "key": "longitude" },
        "time": {
          "key": "datetime",
          "type": "datetime",
          "timezone": "UTC"
        }
      },
      
      "vars": [
        { "id": "obs", "key": "station_value" },
        { "id": "frcst", "key": "wrf_value" }
      ]  
     },
    {
      "id": "boundaries",
      "source": { "type": "geojson", "path": "tests/data/chicago/illinois_county.json" },
      "dims": {
        "id": { "key": "GEOID" }
      }
    }
  ],
  
  "composition": {
    "layout": {
      "columns": 2
    },
    "views": [
      {
        "id": "view1",
        "frame": { "type": "map" },
        "layers": [
          {
            "id": "lt2m",
            "geometry": {
              "type": "isoband",
              "input": { "data": "t2WRFUS", "var": "t2m", "dims": { "time": [68, 69, 70, 71] } },
              "build": [
                {
                  "levels": {
                    "type": "explicit",
                    "values": [0, 5, 10, 15, 20, 25, 30, 35, 40]
                  }
                }
              ],
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "t2m",
                    "scale": {
                      "type": "sequential",
                      "scheme": "Inferno",
                      "domain": [0, 40],
                      "clamp": false
                    }
                  },
                  "opacity": { "value": 0.9 }
                }
              }
            }
          },
          {
            "id": "bound",
            "geometry": {
              "type": "polygon",
              "input": { "data": "boundaries" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                }
              }
            }
          },
          {
            "id": "stations",
            "geometry": {
              "type": "point",
              "input": { "data": "stationsMatch", "var": "obs", "dims": { "time": [68, 69, 70, 71] } },
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "obs",
                    "scale": {
                      "type": "sequential",
                      "scheme": "Inferno",
                      "domain": [0, 40],
                      "clamp": false
                    }
                  },
                  "opacity": { "value": 0.9 }
                }
              }
            }
          }
        ]
      }
    ]
  }
}
