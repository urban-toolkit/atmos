{
  "format": "atmos",
  "data": [
    {
      "id": "hrrr",
      "source": { "type": "netcdf", "path": "input/hrrr/hrrr.nc" },
      "dims": {
        "lat": { "key": "latitude" },
        "lon": { "key": "longitude" },
        "time": { "dim": "time", "key": "time", "type": "datetime", "timezone": "UTC", "format": "" }
      },

      "grid": {
        "type": "curvilinear"
      },
      
      "vars": [
        { "id": "r", "key": "r" },
        { "id": "t", "key": "t" }
      ]
    },
    {
      "id": "us-states",
      "source": { "type": "geojson", "path": "input/geo/us_state.json" },
      "dims": {
        "id": { "key": "GEOID" }
      }
    }
  ],

    "transform": [
    {
      "type": "derive",
      "expr": {
        "op": "sub",
        "args": [
          { "data": "hrrr", "var": "t" },
          { "const": 273.15 }
        ]
      },
      "out": { "data": "hrrrTC", "var": "tC" }
    }
  ],

  "composition": {
    "context": {
      "title": {
        "text": "HRRR Rel. Humidity and Air Temp. (lens)"
      },
       "legends": [
        {
          "title": "Relative Humidity (%)",
          "type": "color",
          "source": [
            {
              "view": "v1",
              "layers": ["l1"],
              "channel": "fill"
            }
          ]
        },
        {
          "title": "Air Temperature (C)",
          "type": "color",
          "source": [
            {
              "view": "v1",
              "layers": ["l2"],
              "channel": "fill"
            }
          ]
        }
      ]
    },

    "interactions": [
      {
        "type": "slider",
        "action": {
          "select": {
            "dim": "time",
            "target": [
              { "view": "v1", "layers": ["l1, l2"] }
            ]
          }
        }
      }
    ],

    "views": [
      {
        "id": "v1",
        "frame": { "type": "map" },
        "context": {
          "title": {
            "template": "Time step {time}"
          }
        },
        "layers": [
          {
            "id": "l1",
            "geometry": {
              "type": "mesh",
              "input": { "data": "hrrr", "var": "r" },
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "r",
                    "scale": {
                      "type": "sequential",
                      "scheme": "Blues",
                      "domain": [0, 100],
                      "clamp": false
                    }
                  },
                  "opacity": { "value": 1.0 }
                }
              }
            }
          },
          {
            "id": "l2",
            "geometry": {
              "type": "mesh",
              "input": { "data": "hrrrTC", "var": "tC"},
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "tC",
                    "scale": {
                      "type": "sequential",
                      "scheme": "RdYlBu",
                      "reverse": true,
                      "domain": [0, 40],
                      "clamp": false
                    }
                  },
                  "opacity": { "value": 1.0 }
                }
              }
            },
            "mask": {
              "type": "bbox",
              "bounds": {
                "west": -94.58524, "south": 28.28046, "east": -76.16991, "north": 42.05382
              },
              "interaction": {
                "on": ["drag", "resize"]
              }
            }
          },
          {
            "id": "us-states",
            "geometry": {
              "type": "polygon",
              "input": { "data": "us-states" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                }
              }
            }
          }
        ]
      }
    ]
  }
}