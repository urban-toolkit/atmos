{
  "format": "atmos",
  "data": [
    {
      "id": "hrrr",
      "source": { "type": "netcdf", "path": "tests/data/hrrr_20240923_20240927/hrrr.nc" },
      "dims": {
        "lat": { "key": "latitude" },
        "lon": { "key": "longitude" },
        "time": { "dim": "time", "key": "time", "type": "datetime", "timezone": "UTC", "format": "" }
      },

      "grid": {
        "type": "curvilinear"
      },
      
      "vars": [
        { "id": "gh", "key": "gh" },
        { "id": "t", "key": "t" }
      ]
    },
    {
      "id": "us-states",
      "source": { "type": "geojson", "path": "tests/data/chicago/us_state.json" },
      "dims": {
        "id": { "key": "GEOID" }
      }
    }
  ],
  
  "transform": [
    {
      "type": "derive",
      "expr": {
        "op": "sub",
        "args": [
          { "data": "hrrr", "var": "t" },
          { "const": 273.15 }
        ]
      },
      "out": { "data": "hrrrTC", "var": "tC" }
    }
  ],

  "composition": {
    "context": {
      "title": {
        "text": "HRRR Air Temperature and Geopotential height ~1013 hPa (gpm)"
      },
       "legends": [
        {
          "title": "HRRR Air Temperature (C)",
          "type": "color",
          "source": [
            {
              "view": "v1",
              "layers": ["l1"],
              "channel": "fill"
            }
          ]
        }
      ]
    },

    "views": [
      {
        "id": "v1",
        "frame": { "type": "map" },
        "context": {
          "title": {
            "template": "Time step {time}"
          }
        },
        "layers": [
          {
            "id": "l1",
            "geometry": {
              "type": "isoband",
              "input": { "data": "hrrrTC", "var": "tC", "dims": { "time": 35 } },
              "build": [
                {
                  "levels": { "type": "step", "start": 0, "stop":40, "step": 2 }
                }
              ],
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "tC",
                    "scale": {
                      "type": "sequential",
                      "scheme": "RdYlBu",
                      "reverse": true,
                      "domain": [0, 40],
                      "clamp": false
                    }
                  },
                  "opacity": { "value": 1.0 }
                }
              }
            }
          },
          {
            "id": "l2",
            "geometry": {
              "type": "isoline",
              "input": { "data": "hrrr", "var": "gh", "dims": { "time": 35 } },
              "build": [
                {
                  "levels": { "type": "step", "start": -200, "stop": 120, "step": 20 }
                }
              ],
              "encoding": {
                "channels": {
                  "stroke": { "value": "#000000" }
                },
                "style": {
                  "strokeWidth": 1,
                  "label": { "enabled": true, "format": ".0f" }
                }
              }
            }
          },
          {
            "id": "us-states",
            "geometry": {
              "type": "polygon",
              "input": { "data": "us-states" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                }
              }
            }
          }
        ]
      }
    ]
  }
}