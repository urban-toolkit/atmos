{
  "format": "atmos",
  "data": [
    {
      "id": "t2WRFUS",
      "source": { "type": "netcdf", "path": "input/chicago/wrfout_built.nc" },
      "dims": {
        "lat": { "key": "XLAT" },
        "lon": { "key": "XLONG" },
        "time": { "dim": "Time", "key": "Times", "type": "datetime", "timezone": "UTC", "format": "" }
      },

      "grid": {
        "type": "curvilinear"
      },
      
      "vars": [
        { "id": "t2m", "key": "T2" }
      ]
    },
    {
      "id": "stationsMatch",
      "type": "dataset",
      "source": {
        "type": "csv",
        "path": "input/chicago/matched_station_wrf.csv"
      },

      "grid": {
        "type": "scattered"
      },

      "dims": {
        "id": { "key": "id" },
        "lat": { "key": "latitude" },
        "lon": { "key": "longitude" },
        "time": {
          "key": "datetime",
          "type": "datetime",
          "timezone": "UTC"
        }
      },
      
      "vars": [
        { "id": "obs", "key": "station_value" },
        { "id": "frcst", "key": "wrf_value" }
      ]  
     },
     {
      "id": "boundaries",
      "source": { "type": "geojson", "path": "input/geo/chicago_county.geojson" },
      "dims": {
        "id": { "key": "GEOID" }
      }
    },
    {
      "id": "boundaries2",
      "source": { "type": "geojson", "path": "input/geo/us_state.json" },
      "dims": {
        "id": { "key": "GEOID" }
      }
    }
  ],

  "composition": {

    "interactions": [
      {
        "type": "click",
        "source": [{ "view": "view1", "layers": ["stations"] }],
        "action": { 
          "select": {
            "dim": "id",
            "target": [{ "view": "view2" }]
          }
        }
      }
    ],

    "context": {
      "title": {
        "text": "Temperature (C): Forecast (isobands) and Observations (points)"
      },
       "legends": [
        {
          "title": "Temperature (C)",
          "type": "color",
          "source": [
            {
              "view": "view1",
              "layers": ["lt2m"],
              "channel": "fill"
            }
          ]
        }
      ]
    },

    "views": [
      {
        "id": "view1",
        "frame": { "type": "map" },
        "context": {
          "title": {
            "template": "Time Step 42"
          }
        },
        "layers": [
          {
            "id": "lt2m",
            "geometry": {
              "type": "isoband",
              "input": { "data": "t2WRFUS", "var": "t2m", "dims": { "time": 42 } },
             "build": [
                {
                  "levels": { "type": "step", "start": 0, "stop":40, "step": 2 }
                }
              ],
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "t2m",
                    "scale": {
                      "type": "sequential",
                      "scheme": "RdYlBu",
                      "reverse": true,
                      "domain": [0, 40],
                      "clamp": false
                    }
                  },
                  "opacity": { "value": 1.0 }
                }
              }
            }
          },
          {
            "id": "bound",
            "geometry": {
              "type": "polygon",
              "input": { "data": "boundaries" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                }
              }
            }
          },
          {
            "id": "bound2",
            "geometry": {
              "type": "polygon",
              "input": { "data": "boundaries2" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                }
              }
            }
          },
          {
            "id": "stations",
            "geometry": {
              "type": "point",
              "input": { "data": "stationsMatch", "var": "obs", "dims": { "time": 42 } },
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "obs",
                    "scale": {
                      "type": "sequential",
                      "scheme": "RdYlBu",
                      "reverse": true,
                      "domain": [0, 40],
                      "clamp": false
                    }
                  },
                  "stroke": {"value": "#000000"},
                  "opacity": { "value": 1.0 }
                }
              }
            }
          }
        ]
      },
      {
        "id": "view2",
        "frame": { "type": "chart" },
        "context": {
          "title": {
            "template": "Time Series with Observed and Forecast Data"
          }
        },
        "floating": true,
        "input": { "data": "stationsMatch" },
        "vegaLite": {
          "transform": [
            {
              "fold": ["obs", "frcst"],
              "as": ["source", "temperature"]
            }
          ],
          "mark": {
            "type": "line",
            "point": true
          },
          "encoding": {
            "x": {
              "field": "time",
              "type": "temporal",
              "title": "Time"
            },
            "y": {
              "field": "temperature",
              "type": "quantitative",
              "title": "Temperature"
            },
            "color": {
              "field": "source",
              "type": "nominal",
              "title": "Series"
            },
            "detail": {
              "field": "id"
            },
            "tooltip": [
              { "field": "id", "type": "nominal", "title": "Station" },
              { "field": "time", "type": "temporal", "title": "Time" },
              { "field": "source", "type": "nominal", "title": "Series" },
              { "field": "temperature", "type": "quantitative", "title": "Value" }
            ]
          }
        }
      }
    ]
  }
}