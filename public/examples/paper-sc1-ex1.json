{
  "data": [
    {
      "id": "wrfR001",
      "source": { "type": "netcdf", "path": "tests/data/wrfout_d03_2011-01-10_00_00_00" },
      "dims": {
        "lat": { "key": "XLAT" },
        "lon": { "key": "XLONG" },
        "time": { "dim": "Time", "key": "Times", "type": "datetime", "timezone": "UTC", "format": "" }
      },

      "grid": {
        "type": "curvilinear"
      },
      
      "vars": [
        { "id": "t2", "key": "T2" }
      ]
    },
    {
      "id": "boundaries",
      "source": { "type": "geojson", "path": "tests/data/grid3P.geojson" },
      "dims": {
        "id": { "key": "GEOID" }
      }
    }
  ],

  "transform": [
    {
      "type": "derive",
      "expr": {
        "op": "add",
        "args": [
          {
            "op": "mul",
            "args": [
              {
                "op": "sub",
                "args": [
                  { "data": "wrfR001", "var": "t2" },
                  { "const": 273.15 }
                ]
              },
              { "const": 1.8 }
            ]
          },
          { "const": 32 }
        ]
      },
      "out": {
        "data": "wrfR001t2F", "var": "t2F" 
      }
    }
  ],
  
  "composition": {
    "layout": {
      "columns": 1
    },
    "context": {
      "title": {
        "text": "Temperature 2m (F)"
      },
      "legends": [
        {
          "title": "Temperature 2m (F)",
          "type": "color",
          "source": [
            {
              "view": "v1",
              "layers": ["l1"],
              "channel": "fill"
            }
          ]
        }
      ]
    },
    "interactions": [
      {
        "type": "slider",
        "action": {
          "select": {
            "dim": "time",
            "target": [
              { "view": "v1", "layers": ["l1"] }
            ]
          }
        }
      }
    ],
    "views": [
      {
        "id": "v1",
        "frame": { "type": "map" },
        "context": {
          "title": {
            "template": "Time Step {time}"
          }
        },
        "layers": [
          {
            "id": "l1",
            "geometry": {
              "type": "mesh",
              "input": { "data": "wrfR001t2F", "var": "t2F" },
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "t2F",
                    "scale": {
                      "type": "sequential",
                      "scheme": "RdYlBu",
                      "domain": [60, 80],
                      "reverse": true,
                      "clamp": false
                    }
                  },
                  "opacity": { "value": 0.9 }
                }
              }
            }
          },
          {
            "id": "bound",
            "geometry": {
              "type": "polygon",
              "input": { "data": "boundaries" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                }
              }
            }
          }
        ]
      }
    ]
  }
}
