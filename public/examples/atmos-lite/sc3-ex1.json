{
  "data": [
    {
      "id": "stations",
      "dims": {
        "lat": "latitude",
        "lng": "longitude",
        "time": "datetime"
      },
      "variables": [
        "temp"
      ],
      "file": [
        {
          "path": "tests/data/stations.csv"
        }
      ]
    },
    {
      "id": "wrf",
      "dims": {
        "lat": "XLAT",
        "lng": "XLONG",
        "time": "Time"
      },
      "variables": [
        "T2"
      ],
      "file": [
        {
          "path": "tests/data/wrfout_d03_2011-01-10_00_00_00"
        }
      ]
    }
  ],
  "transform": [
    {
      "aggregate": {
        "data": "stations.temp",
        "across": "time",
        "op": "mean",
        "frequency": {
          "n": 1,
          "unit": "H"
        }
      },
      "id_out": [
        "obs_h"
      ]
    },
    {
      "join": {
        "data1": "obs_h",
        "data2": "wrf.T2",
        "relationship": "nearest"
      },
      "id_out": [
        "dataobs",
        "dataforecast"
      ]
    }
  ],
  "composition": {
    "views": [
      {
        "id": "v1",
        "type": "map",
        "layers": [
          {
            "id": "l1",
            "geometry": {
              "mark": {
                "type": "point"
              },
              "data": "dataobs",
              "encoding": {
                "color_scale": {
                  "palette": "RdYlBu",
                  "domain": [
                    0,
                    40
                  ]
                }
              }
            }
          },
          {
            "id": "l2",
            "geometry": {
              "mark": {
                "type": "isoband",
                "steps": [
                  0,
                  40,
                  2
                ]
              },
              "data": "dataforecast",
              "encoding": {
                "color_scale": {
                  "palette": "RdYlBu",
                  "domain": [
                    0,
                    40
                  ]
                }
              }
            }
          }
        ]
      }
    ]
  }
}