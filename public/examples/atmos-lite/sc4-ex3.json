{
  "data": [
    {
      "id": "wrf",
      "dims": {
        "lat": "lat",
        "lng": "lng",
        "time": "time"
      },
      "variables": [
        "RAINC",
        "RAINNC"
      ],
      "file": [
        {
          "path": "wrfoutM1.nc"
        },
        {
          "path": "wrfoutM2.nc"
        },
        {
          "path": "wrfoutM3.nc"
        },
        {
          "path": "wrfoutM4.nc"
        },
        {
          "path": "wrfoutM5.nc"
        }
      ]
    }
  ],
  "transform": [
    {
      "derive": {
        "op": "add",
        "left": "wrf.RAINC",
        "right": "wrf.RAINNC"
      },
      "id_out": [
        "rain"
      ]
    },
    {
      "derive": {
        "op": "gt",
        "left": "rain",
        "right": 50
      },
      "id_out": [
        "exceeds"
      ]
    },
    {
      "aggregate": {
        "data": "exceeds",
        "across": "member",
        "op": "mean"
      },
      "id_out": [
        "prob"
      ]
    }
  ],
  "composition": {
    "views": [
      {
        "id": "v1",
        "type": "map",
        "layers": [
          {
            "id": "l1",
            "geometry": {
              "mark": {
                "type": "isoband",
                "steps": [
                  0,
                  1,
                  0.1
                ]
              },
              "data": "prob",
              "encoding": {
                "color_scale": {
                  "palette": "Greens",
                  "domain": [
                    0,
                    1
                  ]
                }
              }
            }
          }
        ]
      }
    ]
  }
}