{
  "format": "atmos",
  "data": [
    {
      "id": "hrrr",
      "source": { "type": "netcdf", "path": "input/hrrr/hrrr.nc" },
      "dims": {
        "lat": { "key": "latitude" },
        "lon": { "key": "longitude" },
        "time": { "dim": "time", "key": "time", "type": "datetime", "timezone": "UTC", "format": "" }
      },

      "grid": {
        "type": "curvilinear"
      },
      
      "vars": [
        { "id": "r", "key": "r" }
      ]
    },
    {
      "id": "us-states",
      "source": { "type": "geojson", "path": "input/geo/us_state.json" },
      "dims": {
        "id": { "key": "GEOID" }
      }
    }
  ],

  "composition": {
    "context": {
      "title": {
        "text": "HRRR Relative Humidity"
      },
       "legends": [
        {
          "title": "Relative Humidity (%)",
          "type": "color",
          "source": [
            {
              "view": "v1",
              "layers": ["l1"],
              "channel": "fill"
            }
          ]
        }
      ]
    },

    "interactions": [
      {
        "type": "slider",
        "action": {
          "select": {
            "dim": "time",
            "target": [
              { "view": "v1", "layers": ["l1"] }
            ]
          }
        }
      }
    ],

    "views": [
      {
        "id": "v1",
        "frame": { "type": "map" },
        "context": {
          "title": {
            "template": "Time step {time}"
          }
        },
        "layers": [
          {
            "id": "l1",
            "geometry": {
              "type": "mesh",
              "input": { "data": "hrrr", "var": "r" },
              "encoding": {
                "channels": {
                  "fill": {
                    "field": "r",
                    "scale": {
                      "type": "sequential",
                      "scheme": "Blues",
                      "domain": [0, 100],
                      "clamp": false
                    }
                  },
                  "opacity": { "value": 1.0 }
                }
              }
            }
          },
          {
            "id": "us-states",
            "geometry": {
              "type": "polygon",
              "input": { "data": "us-states" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                }
              }
            }
          }
        ]
      }
    ]
  }
}