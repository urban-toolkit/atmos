{
  "data": [
    {
      "id": "wrf",
      "dims": {
        "lat": "XLAT",
        "lng": "XLONG",
        "time": "Times"
      },
      "variables": [
        "RAINC",
        "RAINNC"
      ],
      "file": [
        { "path": "input/mrrj/ensemble/m0/wrfout" },
        { "path": "input/mrrj/ensemble/m1/wrfout" },
        { "path": "input/mrrj/ensemble/m2/wrfout" },
        { "path": "input/mrrj/ensemble/m3/wrfout" },
        { "path": "input/mrrj/ensemble/m4/wrfout" }
      ]
    }
  ],
  "transform": [
    {
      "derive": {
        "op": "add",
        "left": "wrf.RAINC",
        "right": "wrf.RAINNC"
      },
      "id_out": [
        "rain"
      ]
    },
    {
      "derive": {
        "op": "gt",
        "left": "rain",
        "right": 50
      },
      "id_out": [
        "exceeds"
      ]
    },
    {
      "aggregate": {
        "data": "exceeds",
        "across": "member",
        "op": "mean"
      },
      "id_out": [
        "prob"
      ]
    }
  ],
  "composition": {
    "interaction": [
      {
        "type": "slider",
        "targets": [
          {
            "view": "v1", "layers": ["l1"]
          }
        ],
        "select": "time"
      }
    ],
    "views": [
      {
        "id": "v1",
        "type": "map",
        "layers": [
          {
            "id": "l1",
            "geometry": {
              "mark": {
                "type": "heatmap"
              },
              "data": "prob",
              "encoding": {
                "color_scale": {
                  "palette": "Greens",
                  "domain": [
                    0,
                    1
                  ]
                }
              }
            }
          }
        ]
      }
    ]
  }
}