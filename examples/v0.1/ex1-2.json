{
  "data": [
    {
      "id": "r001",
      "source": { "type": "netcdf", "path": "data/wrfout_d01_2011-01-12_00_00_00.nc" },
      "dimensions": {
        "latitude": { "key": "XLAT" },
        "longitude": { "key": "XLONG" },
        "time": { "dim": "Time", "key": "Times", "type": "datetime", "timezone": "UTC", "format": "WRF_Times" }
      },
      "variables": [
        { "id": "temp_2m", "key": "T2", "kind": "grid" },
        { "id": "pressure", "key": "P", "kind": "grid" }
      ]
    },
    {
      "id": "boundaries",
      "source": { "type": "geojson", "path": "data/boundaries.geojson" },
      "properties": {
        "geoid": { "key": "GEOID" }
      }
    }
  ],
  
  "composition": {
    "time": {"type": "index", "value": 0},
    
    "context": {
      "controls": [
        {
          "type": "slider",
          "bind": "time"
        }
      ]
    },
    
    "views": [
      {
        "id": "view1",
        "frame": { "type": "map" },
        "layers": [
          {
            "id": "temp",
            "geometry": {
              "type": "mesh",
              "input": { "data": "r001", "variable": "temp_2m" },
              "interpolate": "bilinear",
              "encoding": {
                "type": "mesh",
                "channels": {
                  "fill": {
                    "field": "temp_2m",
                    "scale": { "type": "sequential", "scheme": "RdYlBu" }
                  },
                  "opacity": { "value": 0.9 }
                },
                "style": {
                  "mesh": {
                    "nodataColor": "rgba(0,0,0,0)"
                  }
                }
              }
            }
          },
          {
            "id": "pressure",
            "geometry": {
              "type": "isoline",
              "input": { "data": "r001", "variable": "pressure", "level": { "type": "index", "value": 10 } },
              "build": [
                { "levels": { "type": "step", "start": 980, "stop": 1040, "step": 4 } }
              ],
              "encoding": {
                "type": "isoline",
                "channels": {
                  "stroke": { "value": "#222222" },
                  "opacity": { "value": 0.8 }
                },
                "style": {
                  "isoline": {
                    "label": { "enabled": true, "format": ".0f" },
                    "strokeWidth": 1
                  }
                }
              }
            }
          },
          {
            "id": "bound",
            "geometry": {
              "type": "polygon",
              "input": { "data": "boundaries" },
              "encoding": {
                "channels": {
                  "fill": { "value": "transparent"},
                  "stroke": {"value": "#000000"}
                },
                "style": {
                  "polygon": {
                    "strokeWidth": 1
                  }
                }
              }
            }
          }
        ]
      }
    ]
  }
}