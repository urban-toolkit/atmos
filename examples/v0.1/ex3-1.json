{
  "data": [
    {
      "id": "r001",
      "source": { "type": "netcdf", "path": "data/wrfout_d01_2011-01-12_00_00_00.nc" },
      "dimensions": {
        "latitude": { "key": "XLAT" },
        "longitude": { "key": "XLONG" },
        "time": { "dim": "Time", "key": "Times", "type": "datetime", "timezone": "UTC", "format": "WRF_Times" }
      },
      "variables": [
        { "id": "temp_2m", "key": "T2", "kind": "grid" },
        { "id": "rain", "key": "RAIN", "kind": "grid" }
      ]
    },
    {
      "id": "stations_obs",
      "kind": "dataset",
      "source": {
        "type": "csv",
        "path": "data/stations/observations.csv"
      },

      "dimensions": {
        "site": { "key": "station_id" },
        "latitude": { "key": "lat" },
        "longitude": { "key": "lon" },
        "time": {
          "key": "time",
          "type": "datetime",
          "timezone": "UTC"
        }
      },
      
      "variables": [
        { "id": "name", "key": "name", "kind": "table" },
        { "id": "temp_2m", "key": "temp_2m", "kind": "point" },
        { "id": "rain", "key": "rain", "kind": "point" }
      ],

      "description": "Station observations stored as rows (station_id, lat, lon, time, variables...)."
    }
  ],

  "transform": [
     {
      "id": "match_temp2m",
      "type": "match",

      "forecast": { "data": "r001", "variable": "temp_2m" },
      "obs":      { "data": "stations_obs", "variable": "temp_2m" },

      "space": {
        "method": "nearest",
        "anchor": "obs",
        "preserve": ["name"]
      },

      "time": {
        "anchor": "forecast",
        "bin": "step",
        "op": "mean",
        "coverage": { "minFraction": 0.5 },
        "closed": "left"
      },

      "missing": "skip",

      "as": {
        "variables": { "forecast": "forecast", "obs": "obs" }
      }
    },
    {
      "id": "match_rain",
      "type": "match",

      "forecast": { "data": "r001", "variable": "rain" },
      "obs":      { "data": "stations_obs", "variable": "rain" },

      "space": {
        "method": "nearest",
        "anchor": "obs",
        "preserve": ["name"]
      },

      "time": {
        "target": "forecast",
        "bin": "step",
        "op": "sum",
        "coverage": { "minFraction": 0.5 },
        "closed": "left"
      },

      "missing": "skip",

      "as": {
        "variables": { "forecast": "forecast", "obs": "obs" }
      }
    },
    {
      "type": "verify",
      "id": "rmse_temp_2m",

      "forecast": { "data": "match_temp2m", "variable": "forecast" },
      "obs": { "data": "match_temp2m", "variable": "obs" },

      "op": "rmse",
      "across": "time",

      "missing": "skip",

      "as": {
        "variables": { "rmse": "rmse" }
      }
    },
    {
      "type": "verify",
      "id": "pod_rain",

      "forecast": { "data": "match_rain", "variable": "forecast" },
      "obs": { "data": "match_rain", "variable": "obs" },

      "op": "pod",
      "event": {
        "predicate": {
          "op": "gte",
          "args": [
            { "value": 10 }
          ]
        }
      },
      "across": "time",

      "missing": "skip",
       "as": {
        "variables": { "pod": "pod" }
      }
    },
    {
      "type": "merge",
      "id": "verif_by_station",
      "input": ["rmse_temp_2m", "pod_rain"],
      "missing": "skip"
    }
  ],

  "composition": {
    "time": {"type": "index", "value": 0},
  
    "context": {
      "controls": [
        {
          "type": "slider",
          "bind": "time"
        }
      ]
    },
    
    "views": [
      {
        "id": "view1",
        "frame": {
          "type": "map"
        },

        "layers": [
          {
            "id": "layer_temp2m",
            "geometry": { 
              "id": "isoband_geom_temp2m",
              "type": "isoband", 
              "input": { "data": "r001", "variable": "temp_2m" },
              "build": [
                {
                  "levels": {
                    "type": "explicit",
                    "values": [270, 275, 280, 285, 290]
                  }
                }
              ],
              "encoding": { 
                "id": "isoband_encod_temp2m", 
                "type": "isoband", 
                "channels": { "fill": { "field": "temp2m", "scale": { "scheme": "RdYlBu" }}}
              }
            }
          },
          { 
            "id": "station_obs_temp2m",
            "geometry": {
              "input": { "data": "match_temp2m", "variable": "obs" },
              "type": "point",
              "encoding": { 
                "channels": {
                  "fill": { "value": "#2c7bb6" },
                  "size": { "value": 4 },
                  "opacity": { "value": 0.9 }
                },
                "style": {
                  "point": {
                    "shape": "circle",
                    "strokeWidth": 1
                  }
                }
              }
            }
          }
        ]
      },
      {
        "id": "view2",
        "frame": { "type": "chart" },
        "data": "match_temp2m",
        "vegaLite": {}
      }
    ],

    "interactions": [
      {
        "on": "click",
        "source": { "viewId": "view1", "layerId": "station_obs_temp2m" },

        "do": [
          { "type": "openView", "viewId": "view2" },
          {
            "type": "setFilter",
            "target": { "viewId": "view2" },
            "filter": { "dimension": "site", "value": { "field": "site" } }
          }
        ]
      },
      {
        "on": "hover",
        "source": { "viewId": "view1", "layerId": "station_obs_temp2m" },
        "do": [
          {
            "type": "showTooltip",
            "title": "Verification",
            "items": [
              {
                "label": "RMSE",
                "value": {
                  "data":  "verif_by_station",
                  "variable": "rmse",
                  "filter": { "dimension": "site", "value": { "field": "site" } }
                }
              },
               {
                "label": "POD",
                "value": {
                  "data":  "verif_by_station",
                  "variable": "pod",
                  "filter": { "dimension": "site", "value": { "field": "site" } }
                }
              }
            ]
          }
        ]
      }

    ]
  }
}